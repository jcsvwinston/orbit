go 1.26.5

// Orbit is the pluggable observability/admin product for Nucleus (ADR-019).
// The root module (./) is the in-process orbit.Module consumed by host apps;
// the cluster observability subsystem is split into three modules under
// proto/, agent/, and server/ so the agent, the admin server binary, and the
// proto stubs stay releasable independently while remaining buildable in a
// single `go build ./...` from any module's vantage point.
//
// nucleus/pkg/* is an external dependency of every module here, pinned by
// tag (v1.0.0 since orbit#16) in each module's go.mod.
//
// quarkbridge/ is an opt-in module that depends on both Quark and Nucleus
// (it needs the public SQL ingest, nucleus ADR-020).
//
// quarkdatasource/ is the opt-in Quark implementation of the datasource
// contract (ADR-001): it depends on Quark and on the orbit root module (the
// contract package), keeping Quark out of the core's dependency graph.
use (
	./
	./agent
	./proto
	./quarkbridge
	./quarkdatasource
	./server
)
