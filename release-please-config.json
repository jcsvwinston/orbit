{
  "release-type": "go",
  "include-v-in-tag": true,
  "tag-separator": "/",
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": false,
  "separate-pull-requests": true,
  "draft": false,
  "prerelease": false,
  "changelog-sections": [
    {
      "type": "feat",
      "section": "Added"
    },
    {
      "type": "fix",
      "section": "Fixed"
    },
    {
      "type": "perf",
      "section": "Performance"
    },
    {
      "type": "refactor",
      "section": "Changed"
    },
    {
      "type": "revert",
      "section": "Reverted"
    },
    {
      "type": "docs",
      "section": "Documentation",
      "hidden": true
    },
    {
      "type": "test",
      "section": "Tests",
      "hidden": true
    },
    {
      "type": "chore",
      "section": "Chore",
      "hidden": true
    },
    {
      "type": "ci",
      "section": "CI",
      "hidden": true
    },
    {
      "type": "build",
      "section": "Build",
      "hidden": true
    },
    {
      "type": "style",
      "section": "Style",
      "hidden": true
    }
  ],
  "packages": {
    ".": {
      "package-name": "github.com/jcsvwinston/orbit",
      "release-type": "go",
      "include-component-in-tag": false,
      "exclude-paths": [
        "quarkbridge",
        "quarkdatasource",
        "proto",
        "agent",
        "server"
      ],
      "extra-files": [
        {"type": "generic", "path": "website/docs/intro.md"},
        {"type": "generic", "path": "website/docs/quick-start.md"}
      ]
    },
    "quarkbridge": {
      "package-name": "github.com/jcsvwinston/orbit/quarkbridge",
      "release-type": "go",
      "component": "quarkbridge",
      "include-component-in-tag": true
    },
    "quarkdatasource": {
      "package-name": "github.com/jcsvwinston/orbit/quarkdatasource",
      "release-type": "go",
      "component": "quarkdatasource",
      "include-component-in-tag": true
    },
    "proto": {
      "package-name": "github.com/jcsvwinston/orbit/proto",
      "release-type": "go",
      "component": "proto",
      "include-component-in-tag": true
    },
    "agent": {
      "package-name": "github.com/jcsvwinston/orbit/agent",
      "release-type": "go",
      "component": "agent",
      "include-component-in-tag": true
    },
    "server": {
      "package-name": "github.com/jcsvwinston/orbit/server",
      "release-type": "go",
      "component": "server",
      "include-component-in-tag": true
    }
  }
}
